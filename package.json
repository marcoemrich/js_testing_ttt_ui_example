{
  "name": "ttt-example",
  "version": "1.0.0",
  "description": "Tic Tac Toe – Showcase für JS-Testing mit Vitest, Storybook und Cypress",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:e2e": "start-server-and-test start 1234 cy:run",
    "test:cy-storybook": "start-server-and-test storybook 6006 cy:run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cy:open": "cypress open",
    "cy:run": "cypress run"
  },
  "keywords": [],
  "author": "Marco Emrich",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-links": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cypress": "^15.17.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "start-server-and-test": "^1.14.0",
    "storybook": "^10.4.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
